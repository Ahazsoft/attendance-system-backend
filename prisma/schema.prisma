// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  isApproved Boolean @default(false)
  gender     Boolean  @default(true) // true = male & false = female
  position  String?
  imageUrl  String?
  salary    Decimal?
  telephone String?
  streak    Int      @default(0)

  attendance Attendance[]
}

model Attendance {
  id               Int       @id @default(autoincrement())
  employeeId       Int
  employee         Employee  @relation(fields: [employeeId], references: [id])
  checkInTime      DateTime
  checkOutTime     DateTime?
  workingHours     Float?
  isBssidAvailable Boolean   @default(false)
  isCheckedIn      Boolean   @default(false)
  isLate           Boolean   @default(false)

  overtimes Overtime[]

  @@index([employeeId, checkInTime])
}

// Added Overtime table
model Overtime {
  id            Int        @id @default(autoincrement())
  attendanceId  Int
  attendance    Attendance @relation(fields: [attendanceId], references: [id])
  employeeId    Int // denormalized for faster queries
  overtimeHours Float
  isHoliday     Boolean    @default(false) // true = holiday overtime
  approved      Boolean    @default(false)

  @@index([employeeId])
}

model OfficeSettings {
  id             Int      @id @default(1)
  radius         Int
  gpsLatitude    Decimal
  gpsLongitude   Decimal
  bssid          String
  // Stores only HH:mm:ss in PostgreSQL
  lateThreshold  String
  SecretCode     String @default("secret")
}
